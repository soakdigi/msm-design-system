    {
      "id": "jzlr5i85e",
      "type": "text",
      "x": 702,
      "y": 2329.5,
      "data": {
        "content": "Why MSM?\nMachinery Solutions & Maintenance has established a history of excellence. Our specialised staff are exceedingly gifted and dedicated to help you recognise your company’s equipment servicing demands, with experience in the printing, packaging, furniture & timber industries.",
        "fontSize": 16,
        "color": "#8B2500",
        "bold": false
